{
  "outputDirectory": "public",
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "acuarius.app"
        }
      ],
      "destination": "https://www.acuarius.app/$1",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "www.acuarius.app"
        }
      ],
      "destination": "https://www.acuarius.app/$1",
      "permanent": false
    }
  ]
}
